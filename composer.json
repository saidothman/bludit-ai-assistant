{
    "name": "said-othman/bludit-ai-assistant",
    "description": "AI-powered content assistant plugin for Bludit CMS — generates titles, meta descriptions, and SEO keywords via OpenAI.",
    "type": "bludit-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Said Othman",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "classmap": [
            "src/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "scripts": {
        "test": "vendor/bin/phpunit tests/ --colors=always",
        "test-coverage": "vendor/bin/phpunit tests/ --coverage-text"
    },
    "config": {
        "sort-packages": true
    }
}
